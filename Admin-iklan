<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Admin Iklan</title>

<style>
body{
font-family:Arial;
background:#0f172a;
color:white;
padding:20px;
}

h1{
text-align:center;
}

.container{
max-width:900px;
margin:auto;
}

.card{
background:#1e293b;
padding:15px;
border-radius:12px;
margin-bottom:15px;
}

input,select{
width:100%;
padding:10px;
margin-top:5px;
border-radius:6px;
border:none;
}

button{
margin-top:10px;
padding:10px;
background:#22c55e;
border:none;
border-radius:8px;
color:white;
cursor:pointer;
}

.ad-item{
background:#334155;
padding:10px;
border-radius:8px;
margin-top:10px;
}

</style>
</head>

<body>

<h1>📊 Dashboard Iklan</h1>

<div class="container">

<div class="card">
<h3>Tambah Iklan</h3>

<input id="nama" placeholder="Nama Brand">
<input id="gambar" placeholder="Link Gambar (banner.jpg)">
<select id="tipe">
<option value="banner">Banner</option>
<option value="popup">Popup</option>
<option value="slider">Slider</option>
</select>

<button onclick="tambahIklan()">Tambah Iklan</button>
</div>

<div class="card">
<h3>Daftar Iklan</h3>
<div id="listIklan"></div>
</div>

</div>

<script>
let iklan = JSON.parse(localStorage.getItem("iklan")) || [];

function render(){
let list = document.getElementById("listIklan");
list.innerHTML="";

iklan.forEach((item,index)=>{
list.innerHTML += `
<div class="ad-item">
<b>${item.nama}</b><br>
Tipe: ${item.tipe}<br>
<img src="${item.gambar}" width="100%"><br>
<button onclick="hapus(${index})">Hapus</button>
</div>
`;
});
}

function tambahIklan(){
let nama = document.getElementById("nama").value;
let gambar = document.getElementById("gambar").value;
let tipe = document.getElementById("tipe").value;

if(nama=="" || gambar==""){
alert("Isi semua data");
return;
}

iklan.push({nama,gambar,tipe});
localStorage.setItem("iklan",JSON.stringify(iklan));
render();
}

function hapus(i){
iklan.splice(i,1);
localStorage.setItem("iklan",JSON.stringify(iklan));
render();
}

render();
</script>

</body>
</html>
